  "ddba511fe7bccd3e72e07dfec4879cc6b9317f8e9c0ee1abd61ce22267416895": {
    "describe": {
      "columns": [
        {
          "name": "value",
          "ordinal": 0,
          "type_info": "Jsonb"
        }
      ],
      "nullable": [
        null
      ],
      "parameters": {
        "Left": [
          "Int4",
          "Int4",
          "Text"
        ]
      }
    },
    "query": "SELECT CASE WHEN rp.\"value\" IS NULL THEN p.\"default\" ELSE rp.\"value\" END as \"value\"\n        FROM \"users\" u\n        JOIN \"roles\" r ON r.\"id\" = u.role_id\n        LEFT JOIN \"role_permissions\" rp on rp.\"role_id\" = r.\"id\"\n        LEFT JOIN \"permissions\" p ON p.\"id\" = rp.\"permission_id\"\n        WHERE p.\"application_id\" = $1 AND u.\"id\" = $2 AND p.\"uri\" = $3\n        LIMIT 1;"
  },
